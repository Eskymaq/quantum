--!strict

-- ==========================================
-- KONFIGURACE A SETUP
-- ==========================================
local SCRIPT_VERSION = "0.1.8"
local LIBRARY_ID = "pe_pubmain"
local CONFIG_FILE = "PeakEvolution_Config.json"
local DISCORD_LINK = "https://discord.gg/tvojelink"

if getgenv()[LIBRARY_ID] then 
    pcall(function() getgenv()[LIBRARY_ID]:Destroy() end) 
end

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local function ClearAllHighlights()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Highlight") and obj.Name == "MonsterESP" then 
            obj:Destroy() 
        end
    end
end

-- ==========================================
-- ÚVODNÍ OKNO
-- ==========================================
local function CreateSplashScreen(callback)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "IntroOverlay"
    ScreenGui.Parent = gethui()
    ScreenGui.DisplayOrder = 999

    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 300, 0, 200)
    Frame.Position = UDim2.new(0.5, -150, 0.5, -100)
    Frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Frame.BorderSizePixel = 0
    Frame.Parent = ScreenGui

    local JoinBtn = Instance.new("TextButton")
    JoinBtn.Text = "COPY DISCORD LINK"
    JoinBtn.Size = UDim2.new(0.8, 0, 0.2, 0)
    JoinBtn.Position = UDim2.new(0.1, 0, 0.45, 0)
    JoinBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    JoinBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    JoinBtn.Parent = Frame
    JoinBtn.MouseButton1Click:Connect(function() setclipboard(DISCORD_LINK) end)

    local ExecBtn = Instance.new("TextButton")
    ExecBtn.Text = "EXECUTE SCRIPT"
    ExecBtn.Size = UDim2.new(0.8, 0, 0.2, 0)
    ExecBtn.Position = UDim2.new(0.1, 0, 0.7, 0)
    ExecBtn.BackgroundColor3 = Color3.fromRGB(80, 20, 20)
    ExecBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ExecBtn.Parent = Frame
    ExecBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() callback() end)
end

-- ==========================================
-- HLAVNÍ SKRIPT
-- ==========================================
function LoadMainScript(initialOptions)
    local script_running = true
    local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/nfpw/XXSCRIPT/refs/heads/main/Library/Module.lua"))()
    getgenv()[LIBRARY_ID] = library

    local window = library:CreateWindow({WindowName = "Peak Evolution | V" .. SCRIPT_VERSION}, gethui())
    local my_gui = gethui():GetChildren()[#gethui():GetChildren()] 

    local Options = initialOptions or {
        MonsterESP = false, 
        Noclip = false, 
        SelectedStage = "stage1", 
        ToggleKeyName = "RightShift"
    }
    
    local isBindingKey = false
    local noclip_enabled = Options.Noclip 

    -- Noclip smyčka
    RunService.Stepped:Connect(function()
        if script_running and noclip_enabled and LocalPlayer.Character then
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)

    local main_tab = window:CreateTab("Main")
    local esp_tab = window:CreateTab("ESP")
    local config_tab = window:CreateTab("Settings")

    local main_sec = main_tab:CreateSection("Movement")
    main_sec:CreateToggle("Noclip ( Beta )", Options.Noclip, function(state) 
        Options.Noclip = state 
        noclip_enabled = state
    end)

    local esp_sec = esp_tab:CreateSection("Visuals")
    esp_sec:CreateToggle("Monster ESP", Options.MonsterESP, function(state) 
        Options.MonsterESP = state 
        if not state then ClearAllHighlights() end
    end)

    local config_sec = config_tab:CreateSection("Settings")
    
    local function CreateBindButton()
        return config_sec:CreateButton("Menu Key: " .. Options.ToggleKeyName, function()
            isBindingKey = true
            window:Notify("Keybind", "Press a new key...")
        end)
    end
    local bind_btn = CreateBindButton()

    config_sec:CreateButton("Save Config", function() 
        writefile(CONFIG_FILE, HttpService:JSONEncode(Options)) 
        window:Notify("Settings", "Settings saved!")
    end)

    config_sec:CreateButton("Load Config", function() 
        if isfile(CONFIG_FILE) then 
            local data = HttpService:JSONDecode(readfile(CONFIG_FILE))
            script_running = false 
            ClearAllHighlights()
            library:Destroy()
            task.wait(0.1)
            LoadMainScript(data) 
            window:Notify("Settings", "Settings loaded!")
        end 
    end)

    config_sec:CreateButton("Unload Script", function() 
        script_running = false 
        ClearAllHighlights()
        library:Destroy() 
    end)

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if isBindingKey and input.UserInputType == Enum.UserInputType.Keyboard then
            Options.ToggleKeyName = input.KeyCode.Name
            isBindingKey = false
            bind_btn:Destroy()
            bind_btn = CreateBindButton()
            window:Notify("Keybind", "Key changed to: " .. Options.ToggleKeyName)
        elseif not gameProcessed and input.UserInputType == Enum.UserInputType.Keyboard then
            if input.KeyCode.Name == Options.ToggleKeyName then
                if my_gui then my_gui.Enabled = not my_gui.Enabled end
            end
        end
    end)

    task.spawn(function()
        while script_running do
            if Options.MonsterESP then
                pcall(function()
                    local stage = workspace:FindFirstChild("Stage")
                    if stage and stage:FindFirstChild(Options.SelectedStage) then
                        local target = stage[Options.SelectedStage]:FindFirstChild("monster")
                        if target then
                            for _, m in pairs(target:GetChildren()) do
                                if m:IsA("Model") and m:FindFirstChild("HumanoidRootPart") and not m:FindFirstChild("MonsterESP") then
                                    local h = Instance.new("Highlight")
                                    h.Name = "MonsterESP"
                                    h.FillColor = Color3.fromRGB(255, 50, 50)
                                    h.Parent = m
                                end
                            end
                        end
                    end
                end)
            end
            task.wait(1)
        end
        ClearAllHighlights()
    end)
end

CreateSplashScreen(LoadMainScript)
